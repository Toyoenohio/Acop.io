---
interface Props {
  category: 'Ropa' | 'Medicina' | 'Agua' | 'Comida';
  active: boolean;
  centerId: string;
}

const { category, active, centerId } = Astro.props;

const accentMap = {
  Agua: { bg: 'bg-blue-50', border: 'border-blue-200', icon: 'text-blue-500', label: '💧' },
  Comida: { bg: 'bg-orange-50', border: 'border-orange-200', icon: 'text-orange-500', label: '🍎' },
  Medicina: { bg: 'bg-red-50', border: 'border-red-200', icon: 'text-red-500', label: '💊' },
  Ropa: { bg: 'bg-purple-50', border: 'border-purple-200', icon: 'text-purple-500', label: '👕' },
};

const accent = accentMap[category];
---

{active ? (
  <div class={`need-item flex items-center gap-3 px-3 py-2.5 sm:px-4 sm:py-3 rounded-2xl ${accent.bg} border ${accent.border} transition-all duration-200`}
       data-center-id={centerId}
       data-category={category}
       data-active="true">
    <span class="text-xl sm:text-2xl" role="img" aria-label={category}>{accent.label}</span>
    <div class="flex flex-col min-w-0">
      <span class="text-sm font-bold text-bento-text leading-tight">{category}</span>
      <span class={`text-xs font-semibold ${accent.icon} leading-tight`}>Se necesita</span>
    </div>
  </div>
) : (
  <div class={`need-item flex items-center gap-3 px-3 py-2.5 sm:px-4 sm:py-3 rounded-2xl bg-gray-50 border border-gray-100 opacity-50 transition-all duration-200`}
       data-center-id={centerId}
       data-category={category}
       data-active="false">
    <span class="text-xl sm:text-2xl grayscale" role="img" aria-label={category}>{accent.label}</span>
    <div class="flex flex-col min-w-0">
      <span class="text-sm font-bold text-gray-400 leading-tight">{category}</span>
      <span class="text-xs font-medium text-gray-400 leading-tight">Lleno</span>
    </div>
  </div>
)}
