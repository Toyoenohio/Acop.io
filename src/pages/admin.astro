---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Panel Súper Admin">
  <div class="flex flex-col gap-5 sm:gap-6">
    
    <!-- Header Bar -->
    <div class="card-bento flex items-center justify-between !bg-bento-primary/10 !border-bento-primary/20 animate-fade-up">
      <div>
        <h2 class="text-lg sm:text-xl font-extrabold text-bento-text">Panel Admin</h2>
        <p class="text-xs sm:text-sm text-bento-muted font-medium mt-0.5">Súper Administrador</p>
      </div>
      <button id="logout-btn" class="text-xs sm:text-sm font-bold text-bento-danger bg-white px-3 py-1.5 rounded-lg hover:bg-red-50 transition-colors active:scale-[0.97]">
        Salir
      </button>
    </div>

    <!-- Auth Content (hidden until verified) -->
    <div id="auth-content" class="hidden flex-col gap-5 sm:gap-6">
      
      <!-- ═══════════ SECTION: GESTORES ═══════════ -->
      <section class="card-bento animate-fade-up delay-1">
        <div class="flex items-center justify-between mb-5 pb-3 border-b border-gray-100">
          <h3 class="text-base sm:text-lg font-bold text-bento-text flex items-center gap-2">
            <span class="text-lg">👥</span> Gestores
          </h3>
          <button id="toggle-create-manager" class="text-xs sm:text-sm font-bold text-bento-primary bg-bento-primary/10 px-3 py-1.5 rounded-lg hover:bg-bento-primary/20 transition-colors active:scale-[0.97]">
            + Crear gestor
          </button>
        </div>

        <!-- Create Manager Form (collapsible) -->
        <div id="create-manager-form" class="hidden mb-5 p-4 bg-gray-50 rounded-2xl border border-gray-100">
          <h4 class="text-sm font-bold text-bento-text mb-3">Nuevo gestor</h4>
          <div class="flex flex-col sm:flex-row gap-3">
            <input type="email" id="manager-email" placeholder="email@ejemplo.com" required
                   class="input-bento flex-1">
            <input type="password" id="manager-password" placeholder="Contraseña" required minlength="6"
                   class="input-bento flex-1">
            <button id="create-manager-btn" class="btn-primary whitespace-nowrap text-sm px-4">
              Crear gestor
            </button>
          </div>
          <div id="manager-form-msg" class="hidden text-sm font-semibold p-2 mt-3 rounded-xl text-center"></div>
        </div>

        <!-- Managers list -->
        <div id="managers-list" class="flex flex-col gap-2">
          <div class="text-center py-4 text-bento-muted text-sm font-medium">Cargando gestores...</div>
        </div>
      </section>

      <!-- ═══════════ SECTION: NUEVO CENTRO ═══════════ -->
      <section class="card-bento animate-fade-up delay-2">
        <h3 class="text-base sm:text-lg font-bold text-bento-text mb-5 pb-3 border-b border-gray-100 flex items-center gap-2">
          <span class="text-lg">➕</span> Nuevo centro de acopio
        </h3>
        
        <form id="create-center-form" class="flex flex-col gap-4">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold text-bento-text mb-2">Nombre del centro</label>
              <input type="text" id="center-name" required class="input-bento" placeholder="Ej. Bomberos de Lechería">
            </div>
            
            <div>
              <label class="block text-sm font-semibold text-bento-text mb-2">Teléfono de contacto</label>
              <input type="tel" id="center-contact" required class="input-bento" placeholder="0414-0000000">
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-bento-text mb-2">Dirección</label>
            <input type="text" id="center-address" required class="input-bento" placeholder="Av. Principal de Lechería">
          </div>

          <div>
            <label class="block text-sm font-semibold text-bento-text mb-2">Gestor asignado</label>
            <select id="center-manager" class="input-bento">
              <option value="">— Sin gestor —</option>
            </select>
            <p class="text-xs text-bento-muted mt-1">El gestor podrá actualizar las necesidades de este centro desde su dashboard.</p>
          </div>
          
          <button type="submit" id="submit-btn" class="btn-primary mt-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Crear Centro
          </button>
          
          <div id="form-msg" class="hidden text-sm font-semibold p-3 rounded-xl text-center"></div>
        </form>
      </section>

      <!-- ═══════════ SECTION: CENTROS REGISTRADOS ═══════════ -->
      <section class="animate-fade-up delay-3">
        <h3 class="text-base sm:text-lg font-bold text-bento-text mb-4 flex items-center gap-2">
          <span class="text-lg">📋</span> Centros registrados
        </h3>
        <div id="centers-list" class="flex flex-col gap-3">
          <div class="text-center py-8 text-bento-muted text-sm font-medium">Cargando centros...</div>
        </div>
      </section>
    </div>
    
    <!-- Loading State -->
    <div id="loading" class="card-bento flex flex-col justify-center items-center py-16 gap-3 animate-fade-up">
      <div class="w-8 h-8 border-3 border-bento-primary border-t-transparent rounded-full animate-spin"></div>
      <p class="text-sm text-bento-muted font-medium">Verificando acceso...</p>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../lib/supabase';

  // ─── DOM refs ───
  const authContent = document.getElementById('auth-content');
  const loading = document.getElementById('loading');
  const logoutBtn = document.getElementById('logout-btn');
  const formMsg = document.getElementById('form-msg');
  const form = document.getElementById('create-center-form');
  const centersList = document.getElementById('centers-list');
  const managersList = document.getElementById('managers-list');
  const centerManagerSelect = document.getElementById('center-manager') as HTMLSelectElement;
  const toggleCreateManager = document.getElementById('toggle-create-manager');
  const createManagerForm = document.getElementById('create-manager-form');
  const createManagerBtn = document.getElementById('create-manager-btn');
  const managerFormMsg = document.getElementById('manager-form-msg');

  // ─── State ───
  let allManagers: { id: string; email: string; role: string }[] = [];
  let allCenters: any[] = [];

  // ═══════════════════ AUTH ═══════════════════
  async function checkAuth() {
    const { data: { session } } = await supabase.auth.getSession();
    
    if (!session) {
      window.location.href = '/login';
      return;
    }

    const { data: profile, error: profileError } = await supabase
      .from('profiles')
      .select('role')
      .eq('id', session.user.id)
      .single();

    if (profileError || !profile) {
      console.error("Error al buscar perfil:", profileError);
      if (loading) loading.innerHTML = `<p class="text-bento-danger font-bold text-center">Error: No tienes un perfil creado en la base de datos.<br><span class="text-sm text-bento-muted font-normal mt-2 block">Necesitas ejecutar el script de Trigger en Supabase.</span></p>`;
      return;
    }

    if (profile.role !== 'super_admin') {
      window.location.href = '/dashboard';
      return;
    }

    if (loading && authContent) {
      loading.classList.add('hidden');
      authContent.classList.remove('hidden');
      authContent.classList.add('flex');
    }

    await loadManagers();
    await loadCenters();
  }

  // ═══════════════════ GESTORES ═══════════════════
  async function loadManagers() {
    if (!managersList) return;
    
    const { data, error } = await supabase.rpc('list_managers');
    
    if (error || !data) {
      managersList.innerHTML = `<div class="text-center py-4 text-bento-muted text-sm">Error al cargar gestores. ¿Ejecutaste list_managers.sql?</div>`;
      return;
    }
    
    allManagers = data;
    renderManagers();
    populateManagerSelect();
  }

  function renderManagers() {
    if (!managersList) return;
    
    if (allManagers.length === 0) {
      managersList.innerHTML = `<div class="text-center py-4 text-bento-muted text-sm font-medium">No hay gestores creados aún.</div>`;
      return;
    }

    managersList.innerHTML = allManagers.map(m => `
      <div class="flex items-center gap-3 p-3 rounded-xl bg-gray-50 border border-gray-100">
        <div class="bg-bento-secondary/20 w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0">
          <span class="text-sm">👤</span>
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-sm font-semibold text-bento-text truncate">${m.email}</p>
          <p class="text-xs text-bento-muted">Gestor</p>
        </div>
        <span class="text-xs text-bento-muted font-mono">${m.id.slice(0, 8)}...</span>
      </div>
    `).join('');
  }

  function populateManagerSelect() {
    if (!centerManagerSelect) return;
    centerManagerSelect.innerHTML = '<option value="">— Sin gestor —</option>' +
      allManagers.map(m => `<option value="${m.id}">${m.email}</option>`).join('');
  }

  // Toggle create manager form
  toggleCreateManager?.addEventListener('click', () => {
    createManagerForm?.classList.toggle('hidden');
  });

  // Create manager
  createManagerBtn?.addEventListener('click', async () => {
    const email = (document.getElementById('manager-email') as HTMLInputElement).value.trim();
    const password = (document.getElementById('manager-password') as HTMLInputElement).value;

    if (!email || !password) {
      showManagerMsg('Completá email y contraseña.', 'error');
      return;
    }

    if (password.length < 6) {
      showManagerMsg('La contraseña debe tener al menos 6 caracteres.', 'error');
      return;
    }

    createManagerBtn.disabled = true;
    createManagerBtn.textContent = 'Creando...';

    const { data, error } = await supabase.auth.signUp({ email, password });

    if (error) {
      showManagerMsg('Error: ' + error.message, 'error');
    } else if (data.user) {
      showManagerMsg('✅ Gestor creado. El trigger le asignará perfil automáticamente.', 'success');
      (document.getElementById('manager-email') as HTMLInputElement).value = '';
      (document.getElementById('manager-password') as HTMLInputElement).value = '';
      // Recargar lista después de un breve delay para que el trigger se ejecute
      setTimeout(async () => {
        await loadManagers();
      }, 1500);
    } else {
      showManagerMsg('⚠️ Usuario creado pero requiere confirmación de email.', 'warn');
    }

    createManagerBtn.disabled = false;
    createManagerBtn.textContent = 'Crear gestor';
  });

  function showManagerMsg(text: string, type: 'success' | 'error' | 'warn') {
    if (!managerFormMsg) return;
    managerFormMsg.classList.remove('hidden');
    const colors = {
      success: 'bg-green-50 text-green-700 border border-green-100',
      error: 'bg-red-50 text-bento-danger border border-red-100',
      warn: 'bg-yellow-50 text-yellow-700 border border-yellow-100'
    };
    managerFormMsg.className = `text-sm font-semibold p-2 mt-3 rounded-xl text-center ${colors[type]}`;
    managerFormMsg.textContent = text;
    setTimeout(() => managerFormMsg.classList.add('hidden'), 5000);
  }

  // ═══════════════════ CENTROS ═══════════════════
  async function loadCenters() {
    if (!centersList) return;

    const { data: centers, error } = await supabase
      .from('centers')
      .select('id, name, address, contact, manager_id')
      .order('created_at', { ascending: false });

    if (error || !centers || centers.length === 0) {
      centersList.innerHTML = `
        <div class="text-center py-8 card-bento text-bento-muted text-sm font-medium">
          <span class="text-2xl block mb-2">📦</span>
          No has creado ningún centro aún.
        </div>`;
      allCenters = [];
      return;
    }

    allCenters = centers;
    renderCenters();
  }

  function getManagerEmail(managerId: string | null): string {
    if (!managerId) return 'Sin gestor';
    const m = allManagers.find(m => m.id === managerId);
    return m ? m.email : 'Gestor no encontrado';
  }

  function renderCenters() {
    if (!centersList) return;

    centersList.innerHTML = allCenters.map(c => `
      <div class="card-bento !p-4 flex flex-col gap-3">
        <div class="flex items-center gap-3">
          <div class="bg-bento-primary/20 w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0">
            <span class="text-base">🏠</span>
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-sm font-bold text-bento-text truncate">${c.name}</p>
            <p class="text-xs text-bento-muted truncate">${c.address}</p>
          </div>
          <span class="text-xs font-semibold text-bento-muted bg-bento-surface px-2 py-1 rounded-lg flex-shrink-0">${c.contact}</span>
        </div>
        
        <!-- Manager row -->
        <div class="flex items-center gap-2 pl-13">
          <span class="text-xs text-bento-muted">👤 Gestor:</span>
          <span class="text-xs font-semibold ${c.manager_id ? 'text-bento-text' : 'text-bento-danger'}">${getManagerEmail(c.manager_id)}</span>
          ${allManagers.length > 0 ? `
          <select class="text-xs ml-auto px-2 py-1 rounded-lg border border-gray-200 bg-white text-bento-text" 
                  data-center-id="${c.id}" onchange="window.reassignManager(this)">
            <option value="">— Reasignar —</option>
            <option value="">Sin gestor</option>
            ${allManagers.map(m => `<option value="${m.id}" ${c.manager_id === m.id ? 'selected' : ''}>${m.email}</option>`).join('')}
          </select>
          ` : ''}
        </div>
      </div>
    `).join('');

    // Attach reassign handlers
    (window as any).reassignManager = async (select: HTMLSelectElement) => {
      const centerId = select.dataset.centerId;
      const managerId = select.value || null;
      
      const { error } = await supabase
        .from('centers')
        .update({ manager_id: managerId })
        .eq('id', centerId);
      
      if (error) {
        alert('Error al reasignar: ' + error.message);
      } else {
        await loadCenters();
      }
    };
  }

  // ═══════════════════ CREATE CENTER ═══════════════════
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    if (btn) btn.disabled = true;

    const name = (document.getElementById('center-name') as HTMLInputElement).value;
    const address = (document.getElementById('center-address') as HTMLInputElement).value;
    const contact = (document.getElementById('center-contact') as HTMLInputElement).value;
    const managerId = (document.getElementById('center-manager') as HTMLSelectElement).value || null;

    const { data, error } = await supabase
      .from('centers')
      .insert([{ name, address, contact, manager_id: managerId }])
      .select()
      .single();

    if (formMsg) {
      formMsg.classList.remove('hidden');
      formMsg.className = 'text-sm font-semibold p-3 rounded-xl text-center';
      
      if (error) {
        formMsg.classList.add('bg-red-50', 'text-bento-danger', 'border', 'border-red-100');
        formMsg.textContent = "Error: " + error.message;
      } else {
        const categories = ['Ropa', 'Medicina', 'Agua', 'Comida'];
        const needsData = categories.map(cat => ({
          center_id: data.id,
          category: cat,
          active: true
        }));
        
        await supabase.from('center_needs').insert(needsData);

        formMsg.classList.add('bg-green-50', 'text-bento-success', 'border', 'border-green-100');
        formMsg.textContent = "✅ Centro creado con éxito";
        (form as HTMLFormElement).reset();
        
        await loadCenters();
        
        setTimeout(() => { formMsg.classList.add('hidden'); }, 3000);
      }
    }
    
    if (btn) btn.disabled = false;
  });

  // ═══════════════════ INIT ═══════════════════
  checkAuth();

  logoutBtn?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/login';
  });
</script>
