---
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase';

export const prerender = false;

const { centerId } = Astro.params;

const { data: center } = await supabase
  .from('centers')
  .select('id, name, address')
  .eq('id', centerId)
  .single();

const { data: materials } = await supabase
  .from('materials')
  .select('*')
  .eq('active', true)
  .order('name');

const { data: inventory } = await supabase
  .from('center_inventory')
  .select(`
    id, quantity, updated_at,
    material:materials!center_inventory_material_id_fkey (id, name, emoji, unit)
  `)
  .eq('center_id', centerId)
  .order('quantity', { ascending: false });

const notFound = !center;
const centerIdJson = JSON.stringify(centerId);
---

<Layout title={notFound ? 'No encontrado' : `Inventario — ${center.name}`}>
  {notFound ? (
    <div class="card-bento text-center py-16 animate-fade-up">
      <span class="text-5xl block mb-4">📋</span>
      <h1 class="text-xl font-extrabold text-bento-text mb-2">Centro no encontrado</h1>
      <p class="text-sm text-bento-muted mb-4">El centro que buscás no existe o fue eliminado.</p>
      <a href="/inventario" class="btn-primary text-sm">Ver inventario general</a>
    </div>
  ) : (
    <div class="max-w-lg mx-auto flex flex-col gap-4 animate-fade-up">
      <a href="/inventario" class="text-sm font-semibold text-bento-muted hover:text-bento-text">
        ← Volver al inventario general
      </a>

      <div>
        <h1 class="text-2xl sm:text-3xl font-extrabold text-bento-text tracking-tight">{center.name}</h1>
        <p class="text-sm text-bento-muted font-medium mt-1">{center.address}</p>
      </div>

      <!-- Inventario actual -->
      <div class="card-bento">
        <div class="flex items-center justify-between mb-4 pb-3 border-b border-gray-100">
          <div>
            <h3 class="text-sm font-bold text-bento-text">Stock actual en este centro</h3>
            <p class="text-xs text-bento-muted mt-0.5">Usá los botones + / − para ajustar cantidades al recibir o despachar material.</p>
          </div>
          <span class="text-xs font-semibold bg-bento-primary/20 text-bento-text px-2.5 py-1 rounded-full whitespace-nowrap">
            {inventory?.filter(i => (i as any).quantity > 0).length || 0} activos
          </span>
        </div>

        <div class="flex flex-col gap-2" id="inventory-list">
          {!inventory || inventory.length === 0 ? (
            <p class="text-xs text-bento-muted italic text-center py-6">Este centro todavía no tiene materiales. Agregalos desde la sección de abajo.</p>
          ) : (
            inventory.map((inv: any) => (
              <div class="flex items-center gap-3 p-3 rounded-xl bg-bento-surface border border-gray-100 hover:border-bento-primary/20 transition-colors"
                   data-inventory-id={inv.id} data-material-id={inv.material?.id}>
                <span class="text-2xl">{inv.material?.emoji || '📦'}</span>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-bold text-bento-text">{inv.material?.name || '?'}</p>
                  <p class="text-xs text-bento-muted">Por {inv.material?.unit || 'unidades'} · Actualizado: {inv.updated_at ? new Date(inv.updated_at).toLocaleDateString('es-VE', {day:'numeric',month:'short'}) : '—'}</p>
                </div>
                <div class="flex items-center gap-1.5">
                  <button onclick={`adjustQty('${inv.id}', -1)`} 
                          class="w-9 h-9 rounded-lg bg-red-50 text-red-600 font-bold text-lg flex items-center justify-center hover:bg-red-100 active:scale-90 transition-all"
                          aria-label={`Quitar 1 ${inv.material?.unit || 'unidad'} de ${inv.material?.name || 'material'}`}
                          title={`Reducir stock de ${inv.material?.name || 'material'}`}
                          {inv.quantity <= 0 ? 'disabled' : ''}>−</button>
                  <span class="text-lg font-extrabold text-bento-text w-10 text-center qty-display tabular-nums">{inv.quantity}</span>
                  <button onclick={`adjustQty('${inv.id}', 1)`}
                          class="w-9 h-9 rounded-lg bg-green-50 text-green-600 font-bold text-lg flex items-center justify-center hover:bg-green-100 active:scale-90 transition-all"
                          aria-label={`Agregar 1 ${inv.material?.unit || 'unidad'} de ${inv.material?.name || 'material'}`}
                          title={`Aumentar stock de ${inv.material?.name || 'material'}`}>+</button>
                </div>
              </div>
            ))
          )}
        </div>
      </div>

      <!-- Agregar material existente -->
      <div class="card-bento">
        <h3 class="text-sm font-bold text-bento-text mb-1">➕ Sumar material al inventario</h3>
        <p class="text-xs text-bento-muted mb-3">Agregá stock de un tipo de material que ya existe en el catálogo. Si necesitás crear un tipo nuevo, expandí la sección de abajo.</p>
        
        <div class="flex flex-col sm:flex-row gap-2">
          <select id="new-material" class="input-bento flex-1">
            <option value="">— ¿Cuál material querés agregar? —</option>
            {materials?.map((m: any) => (
              <option value={m.id}>{m.emoji} {m.name} — por {m.unit}</option>
            ))}
          </select>
          <div class="flex items-center gap-2">
            <label class="text-xs font-semibold text-bento-muted whitespace-nowrap">Cantidad:</label>
            <input type="number" id="new-qty" min="0" value="1" 
                   class="input-bento w-20 text-center font-bold" placeholder="0"
                   aria-label="Cantidad inicial de stock" />
          </div>
          <button id="add-btn" class="btn-primary text-sm px-4 whitespace-nowrap">
            Agregar stock
          </button>
        </div>

        <!-- Crear nuevo tipo de material -->
        <details class="mt-4 pt-3 border-t border-gray-100" id="new-material-details">
          <summary class="text-xs font-semibold text-bento-muted cursor-pointer hover:text-bento-text select-none">
            🏷️ ¿El material no está en la lista? Crear un tipo nuevo
          </summary>
          <p class="text-xs text-bento-muted mt-2 mb-2">Definí el nombre, emoji y unidad de medida. Después de crearlo, podrás asignarle stock a este centro.</p>
          <div class="flex flex-col sm:flex-row gap-2">
            <div class="flex-1">
              <label class="text-[11px] font-semibold text-bento-muted block mb-0.5">Nombre del material</label>
              <input type="text" id="new-mat-name" class="input-bento w-full" placeholder="Ej: Colchonetas ignífugas" />
            </div>
            <div>
              <label class="text-[11px] font-semibold text-bento-muted block mb-0.5">Emoji</label>
              <input type="text" id="new-mat-emoji" class="input-bento w-20 text-center" placeholder="🛏️" maxlength="4" />
            </div>
            <div>
              <label class="text-[11px] font-semibold text-bento-muted block mb-0.5">Unidad</label>
              <input type="text" id="new-mat-unit" class="input-bento w-28" placeholder="Ej: unidades, kg, litros" />
            </div>
            <div class="flex items-end">
              <button id="create-mat-btn" class="btn-primary text-xs px-4 py-2.5 whitespace-nowrap h-[42px]">
                Crear tipo
              </button>
            </div>
          </div>
        </details>

        <div id="inv-msg" class="hidden text-sm font-semibold p-2 mt-3 rounded-xl text-center"></div>
      </div>
    </div>
  )}
</Layout>

<script>
  const SUPABASE_URL = (import.meta as any).env?.PUBLIC_SUPABASE_URL || '';
  const SUPABASE_KEY = (import.meta as any).env?.PUBLIC_SUPABASE_ANON_KEY || '';
  const centerId = {centerIdJson};

  // Preserve <details> open state across reloads
  const detailsEl = document.getElementById('new-material-details') as HTMLDetailsElement;
  if (sessionStorage.getItem('inventory-details-open') === 'true') {
    detailsEl?.setAttribute('open', '');
  }
  detailsEl?.addEventListener('toggle', () => {
    sessionStorage.setItem('inventory-details-open', String(detailsEl.open));
  });

  function showMsg(text: string, type: 'success' | 'error') {
    const el = document.getElementById('inv-msg');
    if (!el) return;
    el.classList.remove('hidden');
    el.className = `text-sm font-semibold p-2 mt-3 rounded-xl text-center ${
      type === 'success' ? 'bg-green-50 text-green-700 border border-green-100' 
                         : 'bg-red-50 text-red-700 border border-red-100'
    }`;
    el.textContent = text;
    if (type === 'success') setTimeout(() => el.classList.add('hidden'), 4000);
  }

  // Add existing material to center
  document.getElementById('add-btn')?.addEventListener('click', async () => {
    const matId = (document.getElementById('new-material') as HTMLSelectElement).value;
    const qty = parseInt((document.getElementById('new-qty') as HTMLInputElement).value) || 0;
    if (!matId) return showMsg('Seleccioná un material de la lista', 'error');
    if (qty < 1) return showMsg('La cantidad debe ser al menos 1', 'error');

    const btn = document.getElementById('add-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Guardando...';

    const res = await fetch(`${SUPABASE_URL}/rest/v1/center_inventory`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', apikey: SUPABASE_KEY, authorization: `Bearer ${SUPABASE_KEY}`, Prefer: 'return=minimal' },
      body: JSON.stringify({ center_id: centerId, material_id: matId, quantity: qty })
    });

    if (res.status === 409) {
      await fetch(`${SUPABASE_URL}/rest/v1/center_inventory?center_id=eq.${centerId}&material_id=eq.${matId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', apikey: SUPABASE_KEY, authorization: `Bearer ${SUPABASE_KEY}` },
        body: JSON.stringify({ quantity: qty })
      }).then(async () => {
        showMsg('✅ Stock actualizado — recargando...', 'success');
        setTimeout(() => window.location.reload(), 800);
      });
    } else if (res.ok) {
      showMsg('✅ Material agregado al inventario — recargando...', 'success');
      setTimeout(() => window.location.reload(), 800);
    } else {
      const err = await res.json();
      showMsg('Error: ' + (err.message || 'No se pudo agregar. ¿Las tablas existen en Supabase?'), 'error');
    }

    btn.disabled = false;
    btn.textContent = 'Agregar stock';
  });

  // Create new material type
  document.getElementById('create-mat-btn')?.addEventListener('click', async () => {
    const name = (document.getElementById('new-mat-name') as HTMLInputElement).value.trim();
    const emoji = (document.getElementById('new-mat-emoji') as HTMLInputElement).value.trim() || '📦';
    const unit = (document.getElementById('new-mat-unit') as HTMLInputElement).value.trim() || 'unidades';
    if (!name) return showMsg('Escribí el nombre del material', 'error');

    const btn = document.getElementById('create-mat-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Creando...';

    const res = await fetch(`${SUPABASE_URL}/rest/v1/materials`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', apikey: SUPABASE_KEY, authorization: `Bearer ${SUPABASE_KEY}`, Prefer: 'return=representation' },
      body: JSON.stringify({ name, emoji, unit })
    });

    if (res.ok) {
      showMsg('✅ Tipo de material creado. Recargando página...', 'success');
      setTimeout(() => window.location.reload(), 1000);
    } else {
      const err = await res.json();
      showMsg('Error al crear: ' + (err.message || 'Revisá permisos en Supabase'), 'error');
    }
    btn.disabled = false;
    btn.textContent = 'Crear tipo';
  });

  // Adjust quantity in-place without page reload
  (window as any).adjustQty = async (invId: string, delta: number) => {
    const row = document.querySelector(`[data-inventory-id="${invId}"]`) as HTMLElement;
    const display = row?.querySelector('.qty-display') as HTMLElement;
    if (!display) return;
    
    const current = parseInt(display.textContent || '0');
    const newQty = Math.max(0, current + delta);
    
    // Optimistic update
    display.textContent = String(newQty);
    const minusBtn = row?.querySelector('button:first-child') as HTMLButtonElement;
    if (minusBtn) minusBtn.disabled = newQty <= 0;
    
    await fetch(`${SUPABASE_URL}/rest/v1/center_inventory?id=eq.${invId}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json', apikey: SUPABASE_KEY, authorization: `Bearer ${SUPABASE_KEY}` },
      body: JSON.stringify({ quantity: newQty, updated_at: new Date().toISOString() })
    });
  };
</script>
