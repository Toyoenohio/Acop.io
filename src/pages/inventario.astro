---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

export const prerender = false;

// Obtener centros con inventario agregado
const { data: centers } = await supabase
  .from('centers')
  .select(`
    id, name, address,
    center_inventory (
      quantity,
      material:materials!center_inventory_material_id_fkey (id, name, emoji, unit)
    )
  `)
  .order('name');
---

<Layout title="Inventario">
  <div class="mb-6">
    <h1 class="text-2xl sm:text-3xl font-extrabold text-bento-text tracking-tight">Inventario</h1>
    <p class="text-sm text-bento-muted font-medium mt-1">Materiales disponibles por centro de acopio</p>
  </div>

  <div class="flex flex-col gap-4">
    {!centers || centers.length === 0 ? (
      <div class="card-bento text-center py-16 text-bento-muted">
        <span class="text-4xl block mb-3">📋</span>
        <p class="font-bold text-bento-text">Sin centros registrados</p>
      </div>
    ) : (
      centers.map((c: any, i: number) => {
        const inv = c.center_inventory || [];
        const totalItems = inv.reduce((sum: number, ci: any) => sum + ci.quantity, 0);
        const activeItems = inv.filter((ci: any) => ci.quantity > 0);
        
        return (
          <div class={`card-bento !p-4 animate-fade-up delay-${Math.min(i, 3)}`}>
            <div class="flex items-center justify-between mb-3">
              <div>
                <h2 class="text-base font-bold text-bento-text">{c.name}</h2>
                <p class="text-xs text-bento-muted">{c.address}</p>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-xs font-semibold text-bento-muted">
                  {activeItems.length} materiales · {totalItems} items total
                </span>
                <a href={`/inventario/${c.id}`} class="btn-primary text-xs py-1.5 px-3">
                  Gestionar →
                </a>
              </div>
            </div>

            {activeItems.length === 0 ? (
              <p class="text-xs text-bento-muted italic">Sin materiales registrados</p>
            ) : (
              <div class="flex flex-wrap gap-2">
                {activeItems.map((ci: any) => (
                  <div class="flex items-center gap-2 bg-bento-surface px-3 py-2 rounded-xl">
                    <span class="text-lg">{ci.material?.emoji || '📦'}</span>
                    <div>
                      <p class="text-xs font-semibold text-bento-text">{ci.material?.name || '?'}</p>
                      <p class="text-sm font-extrabold text-bento-primary">{ci.quantity} <span class="text-[10px] text-bento-muted font-medium">{ci.material?.unit || ''}</span></p>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        );
      })
    )}
  </div>
</Layout>
